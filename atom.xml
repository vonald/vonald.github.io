---
layout: feed
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

	<title>Strandlines</title>
	<link href="https://strandlines.blog/atom.xml" rel="self"/>
	<link href="https://strandlines.blog"/>
	<updated>{{ site.time | date_to_xmlschema }}</updated>
	<id> https://strandlines.blog </id>
	<author>
		<name>StephenP</name>
		<email>alienjam@myself.com</email>
	</author>

	{% for post in site.posts %}
		<entry>
			<title>{{ post.title }}</title>
			<link href="https://strandlines.blog{{ post.url }}"/>
			<updated>{{ post.date | date_to_xmlschema }}</updated>
			<id>https://strandlines.blog{{ post.id }}</id>
			<content type="html">{{ post.content | xml_escape }}</content>
		</entry>
	{% endfor %}

</feed>
